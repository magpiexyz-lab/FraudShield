{
  "verify": {
    "0": "test -f .claude/verify-context.json && test -f .claude/fix-log.md && test -d .claude/agent-traces",
    "1": "test -f .claude/build-result.json && python3 -c \"import json; assert json.load(open('.claude/build-result.json'))['exit_code'] == 0\"",
    "2": "ls .claude/agent-traces/*.json >/dev/null 2>&1",
    "3": "python3 -c \"import json,os; fl=open('.claude/fix-log.md').read() if os.path.exists('.claude/fix-log.md') else ''; checks=[('design-critic','.claude/agent-traces/design-critic.json'),('ux-journeyer','.claude/agent-traces/ux-journeyer.json'),('security-fixer','.claude/agent-traces/security-fixer.json')]; errs=[n+': trace has fixes but fix-log missing Fix ('+n+')' for n,p in checks if os.path.exists(p) and len(json.load(open(p)).get('fixes',[]))>0 and 'Fix ('+n not in fl]; assert not errs, '; '.join(errs)\"",
    "4": "test -f .claude/security-merge.json",
    "5": "test -f .claude/e2e-result.json",
    "6": "true",
    "7": {
      "verify": "head -1 .claude/verify-report.md | grep -q '^---$' && tail -1 .claude/verify-history.jsonl | python3 -c 'import json,sys,os; e=json.loads(sys.stdin.read()); ds=e.get(\"dimension_scores\",{}); assert not(ds.get(\"Q_build\",0)>0) or (os.path.exists(\".claude/build-result.json\") and json.load(open(\".claude/build-result.json\")).get(\"exit_code\")==0), \"Q_build>0 but build failed\"'"
    },
    "8": "test -f .claude/patterns-saved.json"
  },
