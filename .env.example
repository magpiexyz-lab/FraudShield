# FraudShield — environment variables
# Copy to .env.local for local development. Never commit real secrets.
# In production, set these in the hosting platform (Vercel → Project → Settings → Environment Variables).

# --- Supabase (database + auth) ---
# NEXT_PUBLIC_SUPABASE_ANON_KEY keeps its name for SDK compatibility; in the
# Supabase Dashboard this is the "Publishable Key" (new keys start with sb_publishable_).
# SUPABASE_SERVICE_ROLE_KEY is auto-injected by the Supabase Vercel Integration and
# by /deploy provisioning — only set manually on a non-Vercel host.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-api-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- PostHog (analytics) ---
# Optional overrides — the analytics library defaults to the team placeholder key
# when these are unset. Set NEXT_PUBLIC_POSTHOG_KEY to your team's real publishable
# key before deploy. POSTHOG_SERVER_KEY (server-only) takes precedence server-side.
NEXT_PUBLIC_POSTHOG_KEY=phc_...
POSTHOG_SERVER_KEY=phc_...

# --- Stripe (payment) ---
# STRIPE_SECRET_KEY starts with sk_; the publishable key with pk_.
# STRIPE_WEBHOOK_SECRET (starts with whsec_) is obtained when registering the webhook.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Upstash Redis (rate limiting) ---
# Required in production. The rate limiter in src/lib/rate-limit.ts uses
# Upstash Redis so per-IP / per-user counters survive Vercel serverless cold
# starts. When both vars are missing, the limiter falls back to an in-memory
# Map — fine for `npm run dev`, NOT safe for production (counters reset on
# every cold start, so the limit becomes ineffective).
# Create a free Redis database at https://console.upstash.com and copy the
# REST URL + REST token from the database's "REST API" section.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# --- Playwright E2E (optional) ---
# E2E_PORT defaults to 3099. Set E2E_BASE_URL to a production URL to skip the local webServer.
# E2E_PORT=3099
# E2E_BASE_URL=http://localhost:3099
